<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="540.0" prefWidth="445.0"
            stylesheets="@../../../../../../FastRail_Station/src/FastRailStation/view/GUI/styles.css"
            xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="FastRailStation.view.controller.PwChangeController">

    <center>
        <GridPane BorderPane.alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="1.7976931348623157E308" minWidth="15.0"  prefWidth="20.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="400.0"                  minWidth="350.0" prefWidth="400.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="1.7976931348623157E308" minWidth="15.0"  prefWidth="20.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints maxHeight="20.0"  minHeight="15.0" prefHeight="15.0" vgrow="SOMETIMES"/>  <!-- 0 -->
                <RowConstraints maxHeight="50.0"  minHeight="30.0" prefHeight="40.0" vgrow="SOMETIMES"/>  <!-- 1 home btn -->
                <RowConstraints maxHeight="15.0"  minHeight="10.0" prefHeight="10.0" vgrow="SOMETIMES"/>  <!-- 2 -->
                <RowConstraints maxHeight="60.0"  minHeight="10.0" prefHeight="50.0" vgrow="SOMETIMES"/>  <!-- 3 title -->
                <RowConstraints maxHeight="30.0"  minHeight="10.0" prefHeight="18.0" vgrow="SOMETIMES"/>  <!-- 4 label email -->
                <RowConstraints maxHeight="20.0"  minHeight="10.0" prefHeight="12.0" vgrow="SOMETIMES"/>  <!-- 5 spacer -->
                <RowConstraints maxHeight="10.0"  minHeight="5.0"  prefHeight="10.0" vgrow="SOMETIMES"/>  <!-- 6 -->
                <RowConstraints maxHeight="40.0"  minHeight="34.0" prefHeight="38.0" vgrow="SOMETIMES"/>  <!-- 7 email field -->
                <RowConstraints maxHeight="15.0"  minHeight="10.0" prefHeight="15.0" vgrow="SOMETIMES"/>  <!-- 8 -->
                <RowConstraints maxHeight="20.0"  minHeight="20.0" prefHeight="20.0" vgrow="SOMETIMES"/>  <!-- 9 label pw -->
                <RowConstraints maxHeight="10.0"  minHeight="5.0"  prefHeight="10.0" vgrow="SOMETIMES"/>  <!-- 10 -->
                <RowConstraints maxHeight="40.0"  minHeight="34.0" prefHeight="38.0" vgrow="SOMETIMES"/>  <!-- 11 pw field -->
                <RowConstraints maxHeight="15.0"  minHeight="10.0" prefHeight="15.0" vgrow="SOMETIMES"/>  <!-- 12 -->
                <RowConstraints maxHeight="20.0"  minHeight="20.0" prefHeight="20.0" vgrow="SOMETIMES"/>  <!-- 13 label confirm -->
                <RowConstraints maxHeight="10.0"  minHeight="5.0"  prefHeight="10.0" vgrow="SOMETIMES"/>  <!-- 14 -->
                <RowConstraints maxHeight="40.0"  minHeight="34.0" prefHeight="38.0" vgrow="SOMETIMES"/>  <!-- 15 confirm field -->
                <RowConstraints maxHeight="15.0"  minHeight="10.0" prefHeight="15.0" vgrow="SOMETIMES"/>  <!-- 16 -->
                <RowConstraints maxHeight="80.0"  minHeight="60.0" prefHeight="70.0" vgrow="SOMETIMES"/>  <!-- 17 button -->
                <RowConstraints maxHeight="40.0"  minHeight="30.0" prefHeight="36.0" vgrow="SOMETIMES"/>  <!-- 18 error label -->
                <RowConstraints maxHeight="1.7976931348623157E308" minHeight="10.0" prefHeight="10.0" vgrow="SOMETIMES"/> <!-- 19 -->
            </rowConstraints>
            <children>
                <!-- Home button -->
                <Button fx:id="btnHome" mnemonicParsing="false" onAction="#handleBtnHome"
                        text="Home"
                        GridPane.columnIndex="1" GridPane.halignment="LEFT"
                        GridPane.rowIndex="1" GridPane.valignment="TOP"/>

                <!-- Title -->
                <Label text="Cambio Password" textFill="WHITE"
                       GridPane.columnIndex="1" GridPane.halignment="CENTER"
                       GridPane.rowIndex="3" GridPane.valignment="CENTER">
                    <font><Font name="System Bold" size="36.0"/></font>
                </Label>

                <!-- Email -->
                <Label text="Email" textFill="WHITE"
                       GridPane.columnIndex="1" GridPane.rowIndex="9">
                    <GridPane.margin><Insets left="50.0"/></GridPane.margin>
                    <font><Font size="15.0"/></font>
                </Label>
                <TextField fx:id="inserisciMail" promptText="Email@Dominio.com"
                           GridPane.columnIndex="1" GridPane.rowIndex="11">
                    <GridPane.margin><Insets left="50.0" right="50.0"/></GridPane.margin>
                </TextField>

                <!-- New password -->
                <Label text="Nuova Password" textFill="WHITE"
                       GridPane.columnIndex="1" GridPane.rowIndex="13">
                    <GridPane.margin><Insets left="50.0"/></GridPane.margin>
                    <font><Font size="15.0"/></font>
                </Label>
                <PasswordField fx:id="inserisciPassword" promptText="la mia nuova password"
                               GridPane.columnIndex="1" GridPane.rowIndex="15">
                    <GridPane.margin><Insets left="50.0" right="50.0"/></GridPane.margin>
                </PasswordField>

                <!-- Confirm password — was missing a label -->
                <Label text="Conferma Nuova Password" textFill="WHITE"
                       GridPane.columnIndex="1" GridPane.rowIndex="4">
                    <GridPane.margin><Insets left="50.0"/></GridPane.margin>
                    <font><Font size="15.0"/></font>
                </Label>
                <PasswordField fx:id="confermaNuovaPassword" promptText="ripeti la password"
                               GridPane.columnIndex="1" GridPane.rowIndex="7">
                    <GridPane.margin><Insets left="50.0" right="50.0"/></GridPane.margin>
                </PasswordField>

                <!-- Submit -->
                <Button fx:id="cambiPassword" mnemonicParsing="false"
                        onAction="#changePassword"
                        prefHeight="58.0" prefWidth="200.0" text="Cambia Password"
                        GridPane.columnIndex="1" GridPane.halignment="CENTER"
                        GridPane.rowIndex="17" GridPane.valignment="CENTER"/>

                <!-- Error / success feedback — was completely missing before -->
                <HBox alignment="CENTER"
                      GridPane.columnIndex="1" GridPane.rowIndex="18">
                    <children>
                        <Label fx:id="feedbackLabel" prefWidth="360.0"
                               wrapText="true" alignment="CENTER"/>
                    </children>
                </HBox>

            </children>
        </GridPane>
    </center>
</BorderPane>
