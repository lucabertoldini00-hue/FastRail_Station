<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" styleClass="root"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="FastRailStation.view.controller.UserController">
    <children>

        <!-- ── Header Navigation ── -->
        <GridPane styleClass="header-nav"
                  AnchorPane.bottomAnchor="550.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0"   AnchorPane.topAnchor="0.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="50.0"  minWidth="10.0" prefWidth="50.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="300.0" minWidth="10.0" prefWidth="300.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="100.0" minWidth="10.0" prefWidth="100.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="100.0" minWidth="10.0" prefWidth="100.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="100.0" minWidth="10.0" prefWidth="100.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="100.0" minWidth="10.0" prefWidth="100.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="100.0" minWidth="10.0" prefWidth="100.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="50.0"  minWidth="10.0" prefWidth="50.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints maxHeight="50.0" minHeight="10.0" prefHeight="50.0" vgrow="SOMETIMES"/>
                <RowConstraints maxHeight="85.0" minHeight="10.0" prefHeight="85.0" vgrow="SOMETIMES"/>
                <RowConstraints maxHeight="50.0" minHeight="10.0" prefHeight="75.0" vgrow="SOMETIMES"/>
            </rowConstraints>
            <children>
                <Label styleClass="logo-text" text="FastRail Station"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label fx:id="navHome"     alignment="CENTER" styleClass="nav-item, nav-item-active"
                       text="Home"     GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <Label fx:id="navArrivi"   alignment="CENTER" styleClass="nav-item"
                       text="Arrivi"   GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                <Label fx:id="navPartenze" alignment="CENTER" styleClass="nav-item"
                       text="Partenze" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
                <Label fx:id="navPrenota"  alignment="CENTER" styleClass="nav-item"
                       text="Prenota"  GridPane.columnIndex="5" GridPane.rowIndex="1"/>
                <Label fx:id="navProfilo"  alignment="CENTER" styleClass="nav-item"
                       text="Profilo"  GridPane.columnIndex="6" GridPane.rowIndex="1"/>
            </children>
        </GridPane>

        <!-- ── Main Content ── -->
        <GridPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0"  AnchorPane.topAnchor="150.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="10.0" prefWidth="200.0"/>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0"  prefWidth="100.0"/>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="10.0" prefWidth="200.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="80.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="140.0" vgrow="SOMETIMES"/>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            </rowConstraints>
            <children>
                <Label alignment="BOTTOM_CENTER" contentDisplay="CENTER"
                       prefHeight="80.0" prefWidth="700.0" styleClass="main-title"
                       text="Cerca il tuo viaggio" textAlignment="CENTER"
                       GridPane.columnIndex="1">
                    <font><Font name="System Bold" size="32.0"/></font>
                </Label>

                <!-- ── Search form — all fields now have fx:id ── -->
                <Pane prefHeight="140.0" prefWidth="700.0"
                      styleClass="search-form-container"
                      GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <children>
                        <Label layoutX="40.0"  layoutY="18.0" styleClass="form-label"
                               text="Stazione di partenza"/>
                        <Label layoutX="40.0"  layoutY="46.0" styleClass="station-display"
                               text="FastRail Station">
                            <font><Font name="System Bold" size="17.0"/></font>
                        </Label>

                        <Label layoutX="205.0" layoutY="38.0" styleClass="swap-icon" text="⇄">
                            <font><Font size="44.0"/></font>
                        </Label>

                        <Label layoutX="280.0" layoutY="18.0" styleClass="form-label"
                               text="Stazione di arrivo"/>
                        <!-- fx:id added so controller can read the value -->
                        <TextField fx:id="searchDestinazione"
                                   layoutX="280.0" layoutY="44.0"
                                   prefHeight="36.0" prefWidth="220.0"
                                   promptText="Destinazione" styleClass="station-input"/>

                        <Label layoutX="516.0" layoutY="18.0" styleClass="form-label" text="Data"/>
                        <!-- fx:id added so controller can read the date -->
                        <DatePicker fx:id="searchData"
                                    layoutX="516.0" layoutY="44.0"
                                    prefHeight="36.0" prefWidth="140.0"
                                    promptText="Data" styleClass="date-picker"/>

                        <!-- CERCA button now has onAction wired -->
                        <Button fx:id="btnCerca"
                                layoutX="672.0" layoutY="44.0"
                                mnemonicParsing="false"
                                onAction="#handleCerca"
                                prefHeight="36.0" prefWidth="80.0"
                                styleClass="search-button" text="CERCA"/>
                    </children>
                </Pane>
            </children>
        </GridPane>

    </children>
</AnchorPane>
